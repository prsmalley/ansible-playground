# Copy this file to inventory.ini and edit for your environment.
# inventory.ini is gitignored to keep host details out of source control.

[appservers]
# Your EC2 instance (the one Terraform provisioned)
# Replace with your actual host or set ansible_host below
# ec2-flaskapp

[appservers:vars]
ansible_user=ubuntu
ansible_python_interpreter=/usr/bin/python3
